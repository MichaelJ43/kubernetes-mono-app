# Remote state (S3 + DynamoDB). For GitHub Actions, keys are derived as:
#   <repo-name>/foundation/terraform.tfstate
#   <repo-name>/k8s-platform/terraform.tfstate
# (repo short name = github.event.repository.name). For local apply, set key to match.

bucket         = "YOUR_STATE_BUCKET"
key            = "kubernetes-mono-app/foundation/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
dynamodb_table = "YOUR_LOCK_TABLE"
